# ─────────────────────────────────────────
# ATLAS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ─────────────────────────────────────────

# ── LLM ──────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Banco de Dados ────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas_db
DATABASE_URL_SYNC=postgresql+psycopg2://atlas:atlas@localhost:5432/atlas_db

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Finance Engine ────────────────────────
FINANCE_ENGINE_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Agno API ──────────────────────────────
AGNO_API_PORT=8001

# ── Evolution API (WhatsApp) ──────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=atlas

# ── n8n ───────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# ── Ambiente ──────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
